{
  "manifest_version": 3,
  "name": "XuperBrain PWA Connector",
  "version": "2.0",
  "description": "Agente autónomo de navegación para LocalEcomer - Sin APIs externas",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://localecomer.store/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content_bridge.js"],
      "run_at": "document_start"
    }
  ]
}
